### fetch_labels node (SaaS DAPO infrastructure linkage)
```yaml
fetch_labels:
  type: dell.nodes.Root
  interfaces:
    cloudify.interfaces.lifecycle:
      precreate:
        executor: central_deployment_agent
        max_retries: 1
        implementation:
          script: |
            from dell import manager
            from dell.state import ctx_parameters as inputs
            client = manager.get_rest_client()
            target_id = inputs['target_deployment_id']
            src = client.deployments.get(target_id)
            labels = [l for l in src.labels if l['key'] == 'csys-target-id']
            if labels:
                client.deployments.set_labels(
                    deployment_id=ctx.deployment.id,
                    labels=[{'csys-target-id': labels[0]['value']}],
                )
```

### ServiceComponent (top-level orchestrator wiring a child blueprint)
```yaml
node_templates:
  jfrog_platform:
    type: dell.nodes.ServiceComponent
    properties:
      resource_config:
        blueprint:
          id: { get_input: [blueprint_ids, jfrog_platform] }
          external_resource: true
          revision_id: { get_input: jfrog_platform_revision_id }
        deployment:
          display_name:
            concat:
              - { get_sys: [deployment, name] }
              - "-jfrog-platform"
          auto_inc_suffix: true
          inputs:
            namespace: { get_input: namespace }
            k8s_credentials: { get_input: k8s_credentials }
            target_deployment_id: { get_input: target_deployment_id }
            database_credentials: { get_input: database_credentials }
            license_secret_ref: { get_input: license_secret_ref }
            chart_version: { get_input: chart_version }
            jfrog_helm_repo_url: { get_input: jfrog_helm_repo_url }
    relationships:
      - target: ingress_nginx
        type: dell.relationships.depends_on
```

